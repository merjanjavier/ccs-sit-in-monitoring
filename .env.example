# Database Credentials
# For local fallback development: file:ccs_database.db
# For production Turso Database: libsql://your-database-name.turso.io
TURSO_DATABASE_URL=file:ccs_database.db
TURSO_AUTH_TOKEN=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=24h

# Server Configuration
PORT=3000
NODE_ENV=development
